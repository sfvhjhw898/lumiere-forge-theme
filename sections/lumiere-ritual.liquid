{{ 'lumiere-brand.css' | asset_url | stylesheet_tag }}

<section class="lumiere-section lri-wrap" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="lri-inner">

    <div class="lri-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lri-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="lri-heading">{{ section.settings.heading | default: 'Your Daily Ritual' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lri-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <ol class="lri-steps" aria-label="{{ section.settings.heading | default: 'Ritual steps' | escape }}">
      {%- for block in section.blocks -%}
        <li class="lri-step lu-card" {{ block.shopify_attributes }}>
          <span class="lri-step__num" aria-hidden="true">0{{ forloop.index }}</span>
          {%- if block.settings.icon_svg != blank -%}
            <div class="lri-step__icon" aria-hidden="true">{{ block.settings.icon_svg }}</div>
          {%- endif -%}
          <div class="lri-step__content">
            <h3 class="lri-step__name">{{ block.settings.name | default: 'Step' }}</h3>
            {%- if block.settings.time != blank -%}
              <p class="lri-step__time">{{ block.settings.time }}</p>
            {%- endif -%}
            {%- if block.settings.desc != blank -%}
              <p class="lri-step__desc">{{ block.settings.desc }}</p>
            {%- endif -%}
          </div>
          {%- if block.settings.image != blank -%}
            <div class="lri-step__img-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                loading="lazy"
                width="200" height="200"
                class="lri-step__img">
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ol>

    {%- if section.settings.cta_label != blank -%}
      <div class="lri-cta-wrap">
        <a class="lri-cta" href="{{ section.settings.cta_url | default: '/collections/all' }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
.lri-wrap { background: var(--lu-rose); }
.lri-inner { max-width: 880px; margin: 0 auto; padding: 0 40px; }

.lri-header { text-align: center; margin-bottom: 56px; }
.lri-eyebrow {
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--lu-pink);
  margin: 0 0 14px;
}
.lri-heading {
  font-family: var(--lu-font-head);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  font-style: italic;
  color: var(--lu-text);
  margin: 0 0 16px;
}
.lri-sub {
  font-size: 15px;
  line-height: 1.75;
  color: var(--lu-muted);
  max-width: 480px;
  margin: 0 auto;
}

.lri-steps {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.lri-step {
  display: grid;
  grid-template-columns: 48px auto 1fr auto;
  align-items: center;
  gap: 20px;
  padding: 24px 28px;
  background: var(--lu-cream);
  border: 1px solid var(--lu-border);
  border-radius: var(--lu-radius);
  box-shadow: var(--lu-shadow);
  transition: box-shadow var(--lu-trans), transform var(--lu-trans);
}
.lri-step:hover {
  box-shadow: var(--lu-shadow-lg);
  transform: translateY(-2px);
}
.lri-step__num {
  font-family: var(--lu-font-head);
  font-size: 28px;
  font-weight: 400;
  font-style: italic;
  color: var(--lu-border);
  line-height: 1;
}
.lri-step__icon svg {
  width: 28px;
  height: 28px;
  stroke: var(--lu-pink);
  fill: none;
  stroke-width: 1.5;
}
.lri-step__content { flex: 1; }
.lri-step__name {
  font-family: var(--lu-font-head);
  font-size: 18px;
  font-weight: 400;
  color: var(--lu-text);
  margin: 0 0 4px;
}
.lri-step__time {
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--lu-pink);
  margin: 0 0 8px;
}
.lri-step__desc {
  font-size: 13px;
  line-height: 1.7;
  color: var(--lu-muted);
  margin: 0;
}
.lri-step__img-wrap { width: 72px; flex-shrink: 0; }
.lri-step__img {
  width: 72px;
  height: 72px;
  object-fit: cover;
  border-radius: 50%;
  border: 2px solid var(--lu-border);
  display: block;
}
.lri-cta-wrap { text-align: center; margin-top: 48px; }
.lri-cta {
  display: inline-block;
  padding: 14px 40px;
  background: var(--lu-pink);
  color: var(--lu-cream);
  text-decoration: none;
  font-size: 12px;
  letter-spacing: .16em;
  text-transform: uppercase;
  border-radius: var(--lu-radius);
  transition: background var(--lu-trans);
}
.lri-cta:hover { background: var(--lu-text); }
.lri-cta:focus-visible { outline: 2px solid var(--lu-pink); outline-offset: 3px; }
@media (max-width: 640px) {
  .lri-inner { padding: 0 16px; }
  .lri-step { grid-template-columns: 36px 1fr; grid-template-rows: auto auto; }
  .lri-step__img-wrap { display: none; }
  .lri-step__icon { display: none; }
}
</style>

{% schema %}
{
  "name": "LUMIERE Ritual",
  "tag": "section",
  "class": "lumiere-section-ritual",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "The Method" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Your Daily Ritual" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text",     "id": "cta_label",  "label": "CTA label",  "default": "Shop Skincare" },
    { "type": "url",      "id": "cta_url",    "label": "CTA URL" },
    { "type": "range",    "id": "padding_top",    "label": "Padding top",    "min": 0, "max": 120, "step": 8, "default": 80 },
    { "type": "range",    "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [{
    "type": "step",
    "name": "Ritual Step",
    "settings": [
      { "type": "text",         "id": "name",     "label": "Step name",  "default": "Cleanse"  },
      { "type": "text",         "id": "time",     "label": "Time",       "default": "60 sec"   },
      { "type": "textarea",     "id": "desc",     "label": "Description" },
      { "type": "html",         "id": "icon_svg", "label": "Icon SVG (optional)" },
      { "type": "image_picker", "id": "image",    "label": "Product image" }
    ]
  }],
  "presets": [{
    "name": "LUMIERE Ritual",
    "blocks": [
      { "type": "step", "settings": { "name": "Cleanse",    "time": "60 sec", "desc": "Apply gently to damp skin using circular motions. Rinse with cool water." } },
      { "type": "step", "settings": { "name": "Tone",       "time": "30 sec", "desc": "Press the toner into skin with clean palms — never rub." } },
      { "type": "step", "settings": { "name": "Serum",      "time": "90 sec", "desc": "3–4 drops warmed between fingers. Press into face and neck." } },
      { "type": "step", "settings": { "name": "Moisturise", "time": "45 sec", "desc": "Seal everything in. Work upward and outward from the centre of the face." } }
    ]
  }]
}
{% endschema %}
