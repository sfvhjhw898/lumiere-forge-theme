{% comment %}
  LUMIÈRE — Main Banner Section
  Centred product showcase hero with spa-like stillness
{% endcomment %}

<style>
  .forge-banner {
    min-height: 100vh;
    min-height: 100dvh;
    background: #F7F3EE;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .forge-banner__eyebrow {
    font-family: var(--forge-font-body);
    font-weight: 400;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(44, 44, 44, 0.4);
    margin-bottom: 3.2rem;
    opacity: 0;
    animation: forge-banner-fade-in 0.6s ease 0.2s forwards;
  }

  .forge-banner__heading {
    margin: 0;
    padding: 0;
  }

  .forge-banner__heading-line {
    font-family: var(--forge-font-heading);
    font-size: clamp(3.6rem, 7vw, 7.5rem);
    color: #2C2C2C;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    padding: 0;
    display: block;
    clip-path: inset(0 100% 0 0);
  }

  .forge-banner__heading-line--light {
    font-weight: 300;
    font-style: italic;
    animation: forge-banner-reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .forge-banner__heading-line--bold {
    font-weight: 600;
    font-style: normal;
    animation: forge-banner-reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards;
  }

  .forge-banner__divider {
    width: 40px;
    height: 1px;
    background: #C9A96E;
    opacity: 0.5;
    margin: 2rem auto 1.2rem;
  }

  .forge-banner__subheading {
    font-family: var(--forge-font-body);
    font-weight: 300;
    font-size: 15px;
    color: rgba(44, 44, 44, 0.55);
    max-width: 42ch;
    line-height: 1.65;
    margin: 0 auto 1.2rem;
  }

  .forge-banner__product {
    margin: 3.2rem auto 0;
    position: relative;
    max-width: 240px;
    width: 100%;
  }

  .forge-banner__product-image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
    animation: forge-breathe 6s ease infinite;
  }

  .forge-banner__cta {
    margin-top: 2.8rem;
  }

  .forge-banner__button {
    display: inline-block;
    font-family: var(--forge-font-body);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: #2C2C2C;
    background: transparent;
    border: 1px solid rgba(44, 44, 44, 0.3);
    padding: 13px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }

  .forge-banner__button:hover {
    background: rgba(44, 44, 44, 0.06);
    border-color: rgba(44, 44, 44, 0.6);
  }

  @keyframes forge-banner-fade-in {
    to {
      opacity: 1;
    }
  }

  @keyframes forge-banner-reveal {
    to {
      clip-path: inset(0 0% 0 0);
    }
  }

  @keyframes forge-breathe {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.02);
    }
  }

  @media (max-width: 768px) {
    .forge-banner {
      padding: 0 2rem;
    }

    .forge-banner__eyebrow {
      font-size: 11px;
      margin-bottom: 2.4rem;
    }

    .forge-banner__heading-line {
      font-size: clamp(2.8rem, 10vw, 3.6rem);
    }

    .forge-banner__subheading {
      font-size: 14px;
      max-width: 32ch;
    }

    .forge-banner__product {
      max-width: 200px;
      margin-top: 2.4rem;
    }

    .forge-banner__cta {
      margin-top: 2rem;
    }

    .forge-banner__button {
      font-size: 13px;
      padding: 11px 28px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .forge-banner__eyebrow,
    .forge-banner__heading-line,
    .forge-banner__product-image {
      animation: none;
      opacity: 1;
      clip-path: none;
      transform: none;
    }
  }
</style>

<section class="forge-banner">
  <div class="forge-banner__eyebrow">
    {{ section.settings.eyebrow | default: 'Luxury Skincare · Est. 2024' }}
  </div>

  <h1 class="forge-banner__heading">
    <span class="forge-banner__heading-line forge-banner__heading-line--light" data-forge-split="words" data-forge-split-anim="reveal">
      {{ section.settings.heading_line1 | default: 'Where Science' }}
    </span>
    <span class="forge-banner__heading-line forge-banner__heading-line--bold" data-forge-split="words" data-forge-split-anim="reveal">
      {{ section.settings.heading_line2 | default: 'Meets Ritual.' }}
    </span>
  </h1>

  <div class="forge-banner__divider"></div>

  <p class="forge-banner__subheading">
    {{ section.settings.subheading | default: 'hand-crafted formulations · clinically proven · zero compromise' }}
  </p>

  <div class="forge-banner__divider"></div>

  <div class="forge-banner__product">
    {%- if section.settings.hero_product != blank -%}
      {%- assign hero_product = all_products[section.settings.hero_product] -%}
      {%- if hero_product.featured_image -%}
        <img
          src="{{ hero_product.featured_image | image_url: width: 500 }}"
          srcset="{{ hero_product.featured_image | image_url: width: 300 }} 300w,
                  {{ hero_product.featured_image | image_url: width: 500 }} 500w,
                  {{ hero_product.featured_image | image_url: width: 700 }} 700w"
          sizes="(max-width: 768px) 200px, 240px"
          alt="{{ hero_product.featured_image.alt | default: hero_product.title }}"
          class="forge-banner__product-image"
          width="500"
          height="667"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    {%- elsif section.settings.image -%}
      <img
        src="{{ section.settings.image | image_url: width: 500 }}"
        srcset="{{ section.settings.image | image_url: width: 300 }} 300w,
                {{ section.settings.image | image_url: width: 500 }} 500w,
                {{ section.settings.image | image_url: width: 700 }} 700w"
        sizes="(max-width: 768px) 200px, 240px"
        alt="{{ section.settings.image.alt | escape }}"
        class="forge-banner__product-image"
        width="500"
        height="667"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>

  {%- if section.settings.button_label != blank -%}
    <div class="forge-banner__cta">
      <a
        href="{{ section.settings.button_link | default: '/collections/all' }}"
        class="forge-banner__button"
        data-forge-magnet="0.3"
      >
        {{ section.settings.button_label | default: 'Discover the Collection' }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Main Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Luxury Skincare · Est. 2024"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "Where Science"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2",
      "default": "Meets Ritual."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "hand-crafted formulations · clinically proven · zero compromise"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "product",
      "id": "hero_product",
      "label": "Hero Product",
      "info": "If selected, will use product's featured image instead of uploaded image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Discover the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}