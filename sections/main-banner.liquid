<section style="min-height:95svh;background:#F7F3EE;display:flex;align-items:center;justify-content:center;padding:60px 24px;">
  <div style="text-align:center;max-width:560px;width:100%;">
    <div style="width:40px;height:1px;background:#C9A96E;margin:0 auto 36px;"></div>
    {%- if section.settings.image -%}
      <img src="{{ section.settings.image | image_url: width: 600 }}" alt="LUMIÈRE hero product" loading="eager" style="max-height:300px;width:auto;object-fit:contain;margin:0 auto 40px;display:block;filter:drop-shadow(0 24px 48px rgba(0,0,0,0.08));">
    {%- endif -%}
    <p style="font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#C9A96E;margin:0 0 16px;font-family:'Playfair Display',Georgia,serif;">— The Ritual Collection —</p>
    <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(28px,3.5vw,40px);font-style:italic;font-weight:400;color:#2C2C2C;line-height:1.3;margin:0 0 16px;">{{ section.settings.heading | default: "Where Science Meets Ritual." }}</h1>
    <p style="font-size:14px;font-style:italic;color:#9B9B9B;margin:0 0 32px;line-height:1.7;font-family:'Source Serif 4',Georgia,serif;">{{ section.settings.subheading | default: "Formulated for transformation. Experienced as ritual." }}</p>
    <div style="width:40px;height:1px;background:#C9A96E;margin:0 auto 32px;"></div>
    <a href="/collections/all" class="lumiere-cta" style="display:inline-block;border:1px solid #2C2C2C;background:transparent;color:#2C2C2C;text-decoration:none;padding:13px 36px;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;transition:background 0.25s,color 0.25s;">Explore the Range</a>
  </div>
</section>

<style>
  .lumiere-cta:hover{background:#2C2C2C!important;color:#F7F3EE!important;}
</style>

{% schema %}
{
  "name": "LUMIÈRE Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Centred hero product"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where Science Meets Ritual."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Formulated for transformation. Experienced as ritual."
    }
  ],
  "presets": [
    {
      "name": "LUMIÈRE Banner"
    }
  ]
}
{% endschema %}